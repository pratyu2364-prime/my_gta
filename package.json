{
  "name": "gully-run",
  "productName": "Gully Run",
  "version": "0.1.0",
  "description": "Gully Run — an open-world driving sandbox.",
  "author": "Pratyush",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pratyush.gullyrun",
    "productName": "Gully Run",
    "directories": { "output": "dist-electron" },
    "files": [
      "index.html",
      "src/**/*",
      "vendor/**/*",
      "assets/**/*",
      "electron/**/*"
    ],
    "win": { "target": ["dir", "nsis"] },
    "linux": { "target": ["dir", "AppImage"], "category": "Game" },
    "mac": { "target": ["dir", "dmg"], "category": "public.app-category.games" }
  }
}
